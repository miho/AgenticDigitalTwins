{
  "compilerOptions": {
    "target": "ES2022",
    "module": "none",
    "lib": ["ES2022", "DOM"],
    "outFile": "dist/renderer/renderer.js",
    "strict": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "declaration": false
  },
  "include": ["src/renderer/**/*.ts"]
}
