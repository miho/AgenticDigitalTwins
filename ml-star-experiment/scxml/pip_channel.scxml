            <script><![CDATA[var tm=_event.data.tm||0;var tt=_event.data.tt||0;for(var i=0;i<16;i++){if((tm&(1<<i))&&!tip_fitted[i]){tip_fitted[i]=true;tip_type[i]=tt;}}var c=0;for(var j=0;j<16;j++)if(tip_fitted[j])c++;active_tip_count=c;if(_event.data.xp!==undefined)pos_x=_event.data.xp;if(_event.data.yp!==undefined){var yb=_event.data.yp;var ya=_event.data._yp_array;for(var k=0;k<16;k++){if(tm&(1<<k))pos_y[k]=ya&&ya[k]!==undefined?ya[k]:yb-k*90;}}var th=_event.data.th!==undefined?_event.data.th:z_traverse;for(var m=0;m<16;m++){if(tm&(1<<m))pos_z[m]=th;}]]></script>
