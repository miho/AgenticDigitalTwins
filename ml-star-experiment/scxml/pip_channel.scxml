            <script><![CDATA[var dv=_event.data.dv||0;var xi=_event.data.xi||1;var td=dv*xi;var t=0;for(var i=0;i<16;i++){if(tip_fitted[i]){volume[i]=Math.max(0,volume[i]-td);t+=volume[i];}}active_volume_total=t;if(_event.data.xp!==undefined)pos_x=_event.data.xp;]]></script>
            <log expr="'Fly disp '+(_event.data.xi||1)+'x'+(_event.data.dv||0)" label="FW"/>
