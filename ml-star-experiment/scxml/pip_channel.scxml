            <script><![CDATA[var dd=_event.data.dd||0;var av=_event.data.av||0;var dv=_event.data.dv||0;var t=0;for(var i=0;i<16;i++){if(tip_fitted[i]){if(dd&(1<<i)){volume[i]+=av;}else{volume[i]=Math.max(0,volume[i]-dv);}t+=volume[i];}}active_volume_total=t;]]></script>
            <log expr="'Simultaneous asp+disp'" label="FW"/>
