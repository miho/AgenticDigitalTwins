      <transition target="idle" event="C0DI"/>
      <transition target="moving" event="C0JM" cond="pos_z.every(function(z){return z&lt;=z_traverse;})&amp;&amp;(_event.data.xp===undefined||(_event.data.xp&gt;=x_min&amp;&amp;_event.data.xp&lt;=x_max))" editor:waypoints="1638,729;1638,707" editor:id="t_01KP58M5ZDB105H7MM65V726QR">
        <script><![CDATA[if(_event.data.xp!==undefined)pos_x=_event.data.xp;if(_event.data.yp!==undefined){var yb=_event.data.yp;var ya=_event.data._yp_array;for(var j=0;j<16;j++)pos_y[j]=ya&&ya[j]!==undefined?ya[j]:yb-j*90;}]]></script>
        <log expr="'Move to X='+pos_x" label="FW"/>
