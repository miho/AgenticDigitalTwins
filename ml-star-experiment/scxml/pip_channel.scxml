        <script><![CDATA[tip_fitted=tip_fitted.map(function(){return false;});tip_type=tip_type.map(function(){return -1;});volume=volume.map(function(){return 0;});for(var i=0;i<16;i++){pos_y[i]=0;pos_z[i]=0;}pos_x=0;active_tip_count=0;active_volume_total=0;last_error=0;]]></script>
