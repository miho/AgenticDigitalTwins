            <script><![CDATA[var tm=_event.data.tm||0;var av=_event.data.av||0;var total=0;for(var i=0;i<16;i++){if(tip_fitted[i]){if(tm&(1<<i))volume[i]=av;total+=volume[i];}}active_volume_total=total;if(_event.data.xp!==undefined)pos_x=_event.data.xp;if(_event.data.yp!==undefined){var yb=_event.data.yp;var ya=_event.data._yp_array;for(var j=0;j<16;j++){if(tip_fitted[j])pos_y[j]=ya&&ya[j]!==undefined?ya[j]:yb-j*90;}}var th_end=_event.data.th!==undefined?_event.data.th:z_traverse;for(var k=0;k<16;k++){if(tip_fitted[k])pos_z[k]=th_end;}]]></script>
            <log expr="'Aspirate vol='+(_event.data.av||0)+' on '+active_tip_count+' ch'" label="FW"/>
          </transition>
          <transition target="tip_empty" event="C0TR" cond="(function(){var tm=_event.data.tm||0;for(var i=0;i&lt;16;i++){if(tip_fitted[i]&amp;&amp;!(tm&amp;(1&lt;&lt;i)))return true;}return false;})()" editor:id="t_partial_eject_tip_empty">
            <script><![CDATA[var tm=_event.data.tm||0;for(var i=0;i<16;i++){if((tm&(1<<i))&&tip_fitted[i]){tip_fitted[i]=false;tip_type[i]=-1;volume[i]=0;}}var c=0;for(var j=0;j<16;j++)if(tip_fitted[j])c++;active_tip_count=c;var t=0;for(var k=0;k<16;k++)if(tip_fitted[k])t+=volume[k];active_volume_total=t;if(_event.data.xp!==undefined)pos_x=_event.data.xp;if(_event.data.yp!==undefined){var yb=_event.data.yp;var ya=_event.data._yp_array;for(var l=0;l<16;l++){pos_y[l]=ya&&ya[l]!==undefined?ya[l]:yb-l*90;}}var th=_event.data.th!==undefined?_event.data.th:z_traverse;for(var m=0;m<16;m++){if(tm&(1<<m))pos_z[m]=th;}]]></script>
            <log expr="'Tip partial eject: '+active_tip_count+' ch still fitted'" label="FW"/>
