          <transition target="tip_loaded" event="C0TR" cond="(function(){var tm=_event.data.tm||0;for(var i=0;i&lt;16;i++){if(tip_fitted[i]&amp;&amp;!(tm&amp;(1&lt;&lt;i)))return true;}return false;})()" editor:id="t_partial_eject_tip_loaded">
