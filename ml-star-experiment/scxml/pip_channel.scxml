            <script><![CDATA[for(var i=0;i<16;i++){tip_fitted[i]=false;tip_type[i]=-1;volume[i]=0;}active_tip_count=0;active_volume_total=0;if(_event.data.xp!==undefined)pos_x=_event.data.xp;if(_event.data.yp!==undefined){var yb=_event.data.yp;var ya=_event.data._yp_array;for(var j=0;j<16;j++){pos_y[j]=ya&&ya[j]!==undefined?ya[j]:yb-j*90;}}var th=_event.data.th!==undefined?_event.data.th:z_traverse;for(var m=0;m<16;m++)pos_z[m]=th;]]></script>
            <log expr="'Tip eject with liquid'" label="FW_WARN"/>
