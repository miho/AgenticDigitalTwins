  <state id="sys_off" editor:x="741" editor:y="2518.0200000000004" editor:width="150" editor:height="75" editor:label="sys_off" editor:color="#2a2a3c" editor:zIndex="0">
    <!-- VENUS's init sequence can arrive with any of the five module-init
         commands as the entry point (order varies — trace shows C0II
         before C0VI). All five must move us into sys_initializing so the
         twin's state machine tracks initialization even when VENUS, not
         our own UI, drives the sequence. -->
    <transition target="sys_initializing" event="C0VI" editor:id="t_01KP46SXEHX45HSJ5JZ7AZYTRA">
      <log expr="'Pre-initialize'" label="SYSTEM"/>
    </transition>
    <transition target="sys_initializing" event="C0DI">
      <log expr="'Pre-initialize (C0DI)'" label="SYSTEM"/>
    </transition>
    <transition target="sys_initializing" event="C0EI">
      <log expr="'Pre-initialize (C0EI)'" label="SYSTEM"/>
    </transition>
    <transition target="sys_initializing" event="C0II">
      <log expr="'Pre-initialize (C0II)'" label="SYSTEM"/>
    </transition>
    <transition target="sys_initializing" event="C0FI">
      <log expr="'Pre-initialize (C0FI)'" label="SYSTEM"/>
    </transition>
  </state>
  <state id="sys_initializing" editor:x="1054" editor:y="2506.0200000000004" editor:width="225" editor:height="75" editor:label="sys_initializing" editor:color="#2a2a3c" editor:zIndex="1">
    <onentry>
      <send event="init.done" delayexpr="'1500ms'"/>
      <log expr="'System initializing...'" label="SYSTEM"/>
    </onentry>
    <transition target="sys_ready" event="init.done" editor:waypoints="906,2531.0200000000004;906,2497.0200000000004;388,2497.0200000000004;388,2531.0200000000004" editor:labelRotation="-90" editor:id="t_01KP46SXEHDYXZMWFGKGXM5T8B"/>
    <!-- Additional init commands arriving during the 1500ms init delay
         stay in the state (re-init is idempotent for the real FW). -->
    <transition target="sys_initializing" event="C0VI"/>
    <transition target="sys_initializing" event="C0DI"/>
    <transition target="sys_initializing" event="C0EI"/>
    <transition target="sys_initializing" event="C0II"/>
    <transition target="sys_initializing" event="C0FI"/>
  </state>
  <state id="sys_ready" editor:x="12" editor:y="2506.0200000000004" editor:width="175" editor:height="75" editor:label="sys_ready" editor:color="#2a2a3c" editor:zIndex="2">
    <onentry>
      <assign location="instrument_initialized" expr="true"/>
      <log expr="'Instrument ready'" label="SYSTEM"/>
    </onentry>
    <!-- VENUS re-sends init commands on every method run. Real FW
         accepts them idempotently when already initialised, so
         self-loop here rather than rejecting or re-running homing. -->
    <transition target="sys_ready" event="C0VI"/>
    <transition target="sys_ready" event="C0DI"/>
    <transition target="sys_ready" event="C0EI"/>
    <transition target="sys_ready" event="C0II"/>
    <transition target="sys_ready" event="C0FI"/>
    <transition target="sys_ready" event="C0KX" editor:waypoints="98.94267515923559,2496.0200000000004;100.05732484076425,2496.0200000000004" editor:id="t_01KP46SXEHJEW1JAR1YKR4W3NV">
      <assign location="left_arm_x" expr="_event.data.xs || left_arm_x"/>
    </transition>
    <transition target="sys_ready" event="C0KR" editor:waypoints="97.82802547770693,2464.0200000000004;101.17197452229291,2464.0200000000004" editor:id="t_01KP46SXEHMB36R5BJYTM1HMS7">
      <assign location="right_arm_x" expr="_event.data.xs || right_arm_x"/>
    </transition>
    <transition target="sys_ready" event="C0CO" editor:waypoints="96.71337579617827,2432.0200000000004;102.28662420382157,2432.0200000000004" editor:id="t_01KP46SXEH4F66X3178JVDTJ1M">
      <assign location="cover_locked" expr="true"/>
